(version 1)
(rule "Custom rule 1"

    (constraint clearance (min 0.11mm))
    (condition "A.Type == 'via' && B.Type == 'pad'"))
(rule "OCBWAY 1"

    (constraint clearance (min 0.11mm))
    (condition "A.Type == 'via' && B.Type == 'pad'"))
(rule Hole_to_hole_distance_1
	(constraint hole_to_hole (min 0.4mm))
)
